# Copy to .env and load before local runs, or set in the shell / HF Space secrets.
# None of these are strictly required for every command — many have defaults in code.

# --- Hugging Face (models, dataset cache, optional Hub push after training) ---
# HF_TOKEN=
# HUGGINGFACE_HUB_TOKEN=

# --- Caches (HF Space / containers: set explicitly to avoid ~/.cache and bad HOME) ---
# HF_HOME=
# HF_DATASETS_CACHE=
# HUGGINGFACE_HUB_CACHE=
# TRANSFORMERS_CACHE=
# TORCHINDUCTOR_CACHE_DIR=
# TRITON_CACHE_DIR=
# XDG_CACHE_HOME=
# TMPDIR=/tmp
# HOME=

# --- ReleaseOps / inference toward a deployed Space ---
# Base URL of the Space (host only, no /outputs/ls). Example: https://user-space.hf.space
# RELEASEOPS_SPACE_URL=

# --- Gradio (demo) ---
# PORT=7860
# GRADIO_ANALYTICS_ENABLED=0
# GRADIO_VERBOSE=0

# --- FastAPI / Space: concurrent env sessions (server) ---
# MAX_CONCURRENT_ENVS=64

# --- HF Space: override writable outputs if default probe fails ---
# RELEASEOPS_OUTPUTS_DIR=/data/outputs

# --- Training (optional; train_grpo sets most cache vars automatically) ---
# TORCH_COMPILE_DISABLE=1
